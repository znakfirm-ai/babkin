generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceType {
  personal
  family
}

enum WorkspaceRole {
  owner
  admin
  member
  viewer
}

enum TransactionKind {
  income
  expense
  transfer
  adjustment
}

enum GoalStatus {
  active
  completed
}

enum DebtorStatus {
  active
  completed
}

enum DebtorDirection {
  RECEIVABLE
  PAYABLE
}

enum BotUserStage {
  NEW_USER
  TRIAL_FREE_USAGE
  TRIAL_PAYWALL
  TRIAL_LIMITED
  ACTIVE_PAID
}

enum BotSessionMode {
  idle
  processing_input
  draft_review
  awaiting_field_input
  awaiting_choice
  saving
  saved_result
  unfinished_draft_block
  capture_error
  save_error
}

enum BotOperationDraftStatus {
  pending_review
  awaiting_field_input
  awaiting_choice
  saving
  saved
  applied
  cancelled
  failed
  superseded
}

enum BotOperationSourceType {
  text
  voice
  receipt
}

model income_sources {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  sort_order   Int      @default(0)
  icon         String?
  is_default   Boolean  @default(false)
  is_archived  Boolean  @default(false)
  archived_at  DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  transactions transactions[]

  @@index([workspace_id])
}

model users {
  id                  String    @id @default(uuid())
  telegram_user_id    String    @unique
  first_name          String?
  username            String?
  active_workspace_id String?

  workspaces_users_active_workspace_idTousers workspaces? @relation("users_active_workspace_id", fields: [active_workspace_id], references: [id])
  workspaces                                  workspaces[] @relation("workspaces_created_by_user_id")
  workspace_members                           workspace_members[]
  workspace_invites                           workspace_invites[] @relation("workspace_invites_created_by_user_id")
  transactions_created                        transactions[] @relation("transactions_created_by_user_id")
  bot_user_state                              bot_user_states?
  bot_session                                 bot_sessions?
  bot_operation_drafts                        bot_operation_drafts[]
  subscriptions                               subscriptions[]
  payments                                    payments[]

  @@index([telegram_user_id])
}

model workspaces {
  id                 String             @id @default(uuid())
  type               WorkspaceType
  name               String?
  icon_emoji         String?
  created_by_user_id String
  created_at         DateTime           @default(now())

  users_workspaces_created_by_user_idTousers users           @relation("workspaces_created_by_user_id", fields: [created_by_user_id], references: [id])
  active_for_users                           users[]         @relation("users_active_workspace_id")
  workspace_members                          workspace_members[]
  workspace_invites                          workspace_invites[] @relation("workspace_invites_workspace_id")
  accounts                                   accounts[]
  categories                                 categories[]
  transactions                               transactions[]
  income_sources                             income_sources[]
  goals                                       goals[]
  debtors                                     debtors[]
  bot_operation_drafts                        bot_operation_drafts[]
  subscriptions                               subscriptions[]
  payments                                    payments[]

  @@index([created_by_user_id])
}

model workspace_members {
  workspace_id String
  user_id      String
  role         WorkspaceRole

  workspaces workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  users      users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([workspace_id, user_id])
  @@index([user_id])
}

model workspace_invites {
  id                String   @id @default(uuid())
  workspace_id      String
  code              String   @unique
  created_by_user_id String
  expires_at        DateTime?
  max_uses          Int?
  uses_count        Int      @default(0)
  is_revoked        Boolean  @default(false)
  created_at        DateTime @default(now())

  workspaces workspaces @relation("workspace_invites_workspace_id", fields: [workspace_id], references: [id], onDelete: Cascade)
  users      users      @relation("workspace_invites_created_by_user_id", fields: [created_by_user_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@index([created_by_user_id])
}

model accounts {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  sort_order   Int      @default(0)
  display_name String?
  type         String
  currency     String
  balance      Decimal  @default(0)
  color        String?
  icon         String?
  icon_emoji   String?
  is_default   Boolean  @default(false)
  is_archived  Boolean  @default(false)
  archived_at  DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  transactions_account transactions[] @relation("transactions_account")
  transactions_from    transactions[] @relation("transactions_from_account")
  transactions_to      transactions[] @relation("transactions_to_account")

  @@index([workspace_id])
}

model categories {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  sort_order   Int      @default(0)
  kind         CategoryKind
  icon         String?
  is_default   Boolean  @default(false)
  is_archived  Boolean  @default(false)
  archived_at  DateTime?
  budget       Decimal? @db.Decimal(18, 2)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  transactions transactions[]

  @@index([workspace_id])
}

model transactions {
  id              String           @id @default(uuid())
  workspace_id    String
  created_by_user_id String?
  kind            TransactionKind
  amount          Decimal      @db.Decimal(18, 2)
  happened_at     DateTime        @default(now())
  created_at      DateTime        @default(now())
  note            String?
  account_id      String?
  category_id     String?
  from_account_id String?
  to_account_id   String?
  income_source_id String?
  goal_id         String?
  debtor_id       String?

  workspace workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  created_by users? @relation("transactions_created_by_user_id", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  account   accounts?  @relation("transactions_account", fields: [account_id], references: [id])
  category  categories? @relation(fields: [category_id], references: [id])
  from_account accounts? @relation("transactions_from_account", fields: [from_account_id], references: [id])
  to_account   accounts? @relation("transactions_to_account", fields: [to_account_id], references: [id])
  income_source income_sources? @relation(fields: [income_source_id], references: [id])
  goal goals? @relation(fields: [goal_id], references: [id])
  debtor debtors? @relation(fields: [debtor_id], references: [id])

  @@index([workspace_id])
  @@index([created_by_user_id])
  @@index([account_id])
  @@index([category_id])
  @@index([from_account_id])
  @@index([to_account_id])
  @@index([income_source_id])
  @@index([goal_id])
  @@index([debtor_id])
}

model goals {
  id             String      @id @default(uuid())
  workspace_id   String
  name           String
  sort_order     Int         @default(0)
  icon           String?
  target_amount  Decimal     @db.Decimal(18, 2)
  current_amount Decimal     @db.Decimal(18, 2) @default(0)
  status         GoalStatus  @default(active)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  completed_at   DateTime?

  workspace workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  transactions transactions[]

  @@index([workspace_id])
}

model debtors {
  id               String       @id @default(uuid())
  workspace_id     String
  name             String
  sort_order       Int          @default(0)
  icon             String?
  issued_at        DateTime
  principal_amount Decimal      @db.Decimal(18, 2)
  due_at           DateTime?
  payoff_amount    Decimal?     @db.Decimal(18, 2)
  status           DebtorStatus @default(active)
  direction        DebtorDirection @default(RECEIVABLE)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  workspace workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  transactions transactions[]

  @@index([workspace_id])
  @@index([workspace_id, status])
  @@index([workspace_id, direction])
}

model bot_user_states {
  user_id                      String       @id
  stage                        BotUserStage @default(NEW_USER)
  successful_operations_count  Int          @default(0)
  paywall_prompted_at          DateTime?
  created_at                   DateTime     @default(now())
  updated_at                   DateTime     @updatedAt

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([stage])
}

model bot_sessions {
  id                  String         @id @default(uuid())
  user_id             String         @unique
  mode                BotSessionMode @default(idle)
  active_draft_id     String?
  active_message_id   Int?
  awaiting_input_type String?
  pending_input_json  Json?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  drafts bot_operation_drafts[]

  @@index([updated_at])
}

model bot_operation_drafts {
  id               String                   @id @default(uuid())
  user_id          String
  workspace_id     String
  session_id       String?
  type             String?
  amount           Decimal?                 @db.Decimal(18, 2)
  from_entity_id   String?
  to_entity_id     String?
  category_id      String?
  income_source_id String?
  happened_at      DateTime?
  description      String?
  source_type      BotOperationSourceType
  source_raw       String?
  parsed_confidence Float?
  status           BotOperationDraftStatus  @default(pending_review)
  chat_id          String
  source_message_id Int?
  live_message_id  Int?
  lookup_json      Json?
  payload_json     Json?
  created_at       DateTime                 @default(now())
  updated_at       DateTime                 @updatedAt

  users      users       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspaces workspaces  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  sessions   bot_sessions? @relation(fields: [session_id], references: [id], onDelete: SetNull)

  @@index([user_id, status])
  @@index([workspace_id])
  @@index([session_id])
  @@index([chat_id])
}

model subscriptions {
  id                         String               @id @default(uuid())
  user_id                    String
  workspace_id               String?
  plan_code                  SubscriptionPlanCode
  status                     SubscriptionStatus
  provider                   PaymentProvider
  provider_customer_id       String?
  provider_payment_method_id String?
  trial_started_at           DateTime?
  trial_ends_at              DateTime?
  current_period_starts_at   DateTime?
  current_period_ends_at     DateTime?
  cancel_at_period_end       Boolean              @default(false)
  cancelled_at               DateTime?
  ended_at                   DateTime?
  next_renewal_at            DateTime?
  reminder_sent_at           DateTime?
  created_at                 DateTime             @default(now())
  updated_at                 DateTime             @updatedAt

  users       users               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspaces  workspaces?         @relation(fields: [workspace_id], references: [id], onDelete: SetNull)
  payments    payments[]
  events      subscription_events[]

  @@index([user_id])
  @@index([status])
  @@index([next_renewal_at])
}

model payments {
  id                         String               @id @default(uuid())
  subscription_id            String
  user_id                    String
  workspace_id               String?
  provider                   PaymentProvider
  provider_payment_id        String               @unique
  provider_idempotence_key   String?              @unique
  type                       PaymentType
  status                     PaymentStatus
  amount_value               Decimal              @db.Decimal(18, 2)
  amount_currency            String
  plan_code                  SubscriptionPlanCode
  is_trial                   Boolean              @default(false)
  provider_payment_method_id String?
  raw_payload_json           Json?
  paid_at                    DateTime?
  created_at                 DateTime             @default(now())
  updated_at                 DateTime             @updatedAt

  subscriptions subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  users         users         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspaces    workspaces?   @relation(fields: [workspace_id], references: [id], onDelete: SetNull)

  @@index([subscription_id])
  @@index([user_id])
  @@index([status])
}

model subscription_events {
  id              String                @id @default(uuid())
  subscription_id String
  event_type      SubscriptionEventType
  payload_json    Json?
  created_at      DateTime              @default(now())

  subscriptions subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([subscription_id, created_at])
}

enum CategoryKind {
  income
  expense
}

enum SubscriptionPlanCode {
  personal_monthly
  personal_shared_monthly
}

enum SubscriptionStatus {
  pending_initial_payment
  trialing
  active
  past_due
  cancelled
  expired
}

enum PaymentProvider {
  yookassa
}

enum PaymentType {
  trial
  recurring
  one_time
}

enum PaymentStatus {
  pending
  waiting_for_capture
  succeeded
  canceled
  failed
}

enum SubscriptionEventType {
  trial_payment_created
  trial_payment_succeeded
  trial_activated
  recurring_payment_created
  recurring_payment_succeeded
  recurring_payment_failed
  subscription_cancelled
  subscription_expired
}
